# Copy this to a real `.env` file locally (don't commit it).
# In production, set these as environment variables in your host's dashboard.

# --- Database (Turso / libSQL) ---
# Leave both empty to use the local SQLite file at ./data/gcfinance.sqlite (dev only).
# In production, paste the URL and token from the Turso dashboard.
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# --- App ---
# Long random string. Run: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Initial admin password (only used the first time the DB is seeded).
ADMIN_PASSWORD=admin123

# Render sets PORT automatically. Defaults to 3000 locally.
# PORT=3000

# Set to "production" on hosted environments so cookies are sent over HTTPS only.
NODE_ENV=development
