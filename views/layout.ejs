<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#054e5f">
  <title><%= title ? title + ' · ' : '' %><%= brand.name %></title>
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Cpath d='M32 3 L57 12 V31 C57 47 46 57 32 61 C18 57 7 47 7 31 V12 Z' fill='%23054e5f'/%3E%3Ctext x='32' y='42' font-size='26' font-weight='800' text-anchor='middle' fill='%23da8850' font-family='Arial,sans-serif'%3EGC%3C/text%3E%3C/svg%3E">
  <!-- Precompiled Tailwind (no in-browser CDN — much faster) -->
  <link rel="stylesheet" href="/css/tailwind.css">
  <link rel="stylesheet" href="/css/styles.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="bg-slate-100 text-slate-800 font-sans antialiased min-h-screen flex flex-col">

  <%- include('partials/loader') %>

  <%- include('partials/topbar') %>

  <div class="flex flex-1">
    <%- include('partials/sidebar') %>

    <main class="flex-1 min-w-0 lg:ml-64 pt-4 pb-24 lg:pb-10 px-4 sm:px-6 lg:px-8">
      <% if (typeof flash !== 'undefined' && flash) { %>
        <%- include('partials/flash') %>
      <% } %>
      <%- body %>
      <footer class="mt-16 pt-6 border-t border-slate-200 text-center text-xs text-slate-500">
        <p>&copy; <%= brand.year %> <span class="font-semibold text-slate-700"><%= brand.name %></span> · Owned by <%= brand.owner %></p>
        <p class="mt-1">Developed by <a href="<%= brand.devUrl %>" target="_blank" rel="noopener" class="text-brand-600 font-semibold hover:underline"><%= brand.devCredit %></a></p>
      </footer>
    </main>
  </div>

  <%- include('partials/mobile-nav') %>

  <script src="/js/app.js"></script>
  <script src="/js/searchable-select.js"></script>
</body>
</html>
