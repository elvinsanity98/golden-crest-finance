<%- include('../partials/page-header', { heading: 'Borrowers', eyebrow: 'Customer Directory', subtitle: 'All borrowers and their loan history.', actions: '<a href="/borrowers/new" class="bg-brand-500 hover:bg-brand-400 text-slate-900 font-semibold px-4 py-2 rounded-lg text-sm shadow">+ New Borrower</a>' }) %>

<form method="GET" class="mb-4">
  <div class="relative">
    <input name="q" value="<%= q %>" placeholder="Search by name, phone, or ID number..." class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-slate-300 focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 absolute left-3 top-2.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
  </div>
</form>

<% if (borrowers.length === 0) { %>
  <div class="bg-white rounded-xl shadow-sm border border-slate-200">
    <%- include('../partials/empty', {
      icon: 'M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-5a4 4 0 11-8 0 4 4 0 018 0zm6 0a4 4 0 11-8 0 4 4 0 018 0z',
      title: q ? 'No matches found' : 'No borrowers yet',
      message: q ? 'Try a different name, phone, or ID number.' : 'Add your first borrower to start tracking loans and collections.',
      actionHref: q ? '' : '/borrowers/new',
      actionLabel: '+ Add Borrower'
    }) %>
  </div>
<% } else { %>
  <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
    <div class="hidden md:block overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-slate-50 text-xs font-bold uppercase tracking-wider text-slate-500">
          <tr>
            <th class="px-5 py-3 text-left">Name</th>
            <th class="px-5 py-3 text-left">Phone</th>
            <th class="px-5 py-3 text-left">Address</th>
            <th class="px-5 py-3 text-center">Loans</th>
            <th class="px-5 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% borrowers.forEach(b => { %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-3">
                <a href="/borrowers/<%= b.id %>" class="font-semibold text-slate-900 hover:text-brand-600"><%= b.full_name %></a>
                <% if (b.id_number) { %><div class="text-xs text-slate-500"><%= b.id_number %></div><% } %>
              </td>
              <td class="px-5 py-3 text-slate-600"><%= b.phone || '—' %></td>
              <td class="px-5 py-3 text-slate-600 truncate max-w-xs"><%= b.address || '—' %></td>
              <td class="px-5 py-3 text-center">
                <span class="inline-block bg-slate-100 text-slate-700 text-xs font-semibold px-2 py-0.5 rounded"><%= b.loan_count %> total</span>
                <% if (b.active_count > 0) { %><span class="inline-block bg-brand-100 text-brand-800 text-xs font-semibold px-2 py-0.5 rounded ml-1"><%= b.active_count %> active</span><% } %>
              </td>
              <td class="px-5 py-3 text-right whitespace-nowrap">
                <a href="/loans/new?borrower_id=<%= b.id %>" class="text-xs font-semibold text-brand-600 hover:underline mr-3">+ Loan</a>
                <a href="/borrowers/<%= b.id %>" class="text-xs font-semibold text-slate-600 hover:underline">View</a>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <ul class="md:hidden divide-y divide-slate-100">
      <% borrowers.forEach(b => { %>
        <li class="px-4 py-3">
          <a href="/borrowers/<%= b.id %>" class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-brand-100 text-brand-700 flex items-center justify-center font-bold flex-shrink-0"><%= b.full_name.charAt(0).toUpperCase() %></div>
            <div class="flex-1 min-w-0">
              <div class="font-semibold text-slate-900 truncate"><%= b.full_name %></div>
              <div class="text-xs text-slate-500 truncate"><%= b.phone || '—' %> · <%= b.loan_count %> loans</div>
            </div>
            <% if (b.active_count > 0) { %>
              <span class="bg-brand-100 text-brand-800 text-xs font-semibold px-2 py-0.5 rounded flex-shrink-0"><%= b.active_count %> active</span>
            <% } %>
          </a>
        </li>
      <% }); %>
    </ul>
  </div>
<% } %>
