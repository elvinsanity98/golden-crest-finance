<%- include('../partials/page-header', { heading: 'Edit Borrower', subtitle: borrower.full_name }) %>

<% if (errors) { %>
  <div class="mb-4 rounded-lg px-4 py-3 text-sm bg-red-50 text-red-800 border border-red-200"><%= errors %></div>
<% } %>

<form method="POST" action="/borrowers/<%= borrower.id %>?_method=PUT" class="bg-white rounded-xl shadow-sm border border-slate-200 p-5 sm:p-6 space-y-4 max-w-2xl">
  <div>
    <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">Full Name *</label>
    <input name="full_name" required value="<%= borrower.full_name %>" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:ring-2 focus:ring-brand-500 focus:border-transparent">
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">Phone</label>
      <input name="phone" value="<%= borrower.phone || '' %>" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:ring-2 focus:ring-brand-500 focus:border-transparent">
    </div>
    <div>
      <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">Email</label>
      <input name="email" type="email" value="<%= borrower.email || '' %>" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:ring-2 focus:ring-brand-500 focus:border-transparent">
    </div>
  </div>
  <div>
    <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">Address</label>
    <input name="address" value="<%= borrower.address || '' %>" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:ring-2 focus:ring-brand-500 focus:border-transparent">
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">ID Number</label>
      <input name="id_number" value="<%= borrower.id_number || '' %>" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:ring-2 focus:ring-brand-500 focus:border-transparent">
    </div>
    <div>
      <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">Occupation</label>
      <input name="occupation" value="<%= borrower.occupation || '' %>" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:ring-2 focus:ring-brand-500 focus:border-transparent">
    </div>
  </div>
  <div>
    <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">Notes</label>
    <textarea name="notes" rows="3" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:ring-2 focus:ring-brand-500 focus:border-transparent"><%= borrower.notes || '' %></textarea>
  </div>
  <div class="flex gap-2 pt-2">
    <button class="bg-brand-500 hover:bg-brand-400 text-slate-900 font-bold px-5 py-2.5 rounded-lg shadow text-sm">Save Changes</button>
    <a href="/borrowers/<%= borrower.id %>" class="bg-slate-200 hover:bg-slate-300 text-slate-700 font-semibold px-5 py-2.5 rounded-lg text-sm">Cancel</a>
  </div>
</form>
