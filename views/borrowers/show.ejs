<div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
  <div class="flex items-center gap-4">
    <div class="w-14 h-14 rounded-full bg-gradient-to-br from-brand-400 to-brand-600 text-slate-900 flex items-center justify-center text-xl font-extrabold shadow"><%= borrower.full_name.charAt(0).toUpperCase() %></div>
    <div>
      <div class="text-xs font-bold uppercase tracking-wider text-brand-600">Borrower</div>
      <h1 class="text-2xl sm:text-3xl font-extrabold text-slate-900"><%= borrower.full_name %></h1>
      <% if (borrower.occupation) { %><div class="text-sm text-slate-500"><%= borrower.occupation %></div><% } %>
    </div>
  </div>
  <div class="flex flex-wrap gap-2">
    <a href="/loans/new?borrower_id=<%= borrower.id %>" class="bg-brand-500 hover:bg-brand-400 text-slate-900 font-semibold px-4 py-2 rounded-lg text-sm shadow">+ New Loan</a>
    <a href="/borrowers/<%= borrower.id %>/edit" class="bg-slate-200 hover:bg-slate-300 text-slate-700 font-semibold px-4 py-2 rounded-lg text-sm">Edit</a>
    <form action="/borrowers/<%= borrower.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this borrower? Loan history will also be removed.');">
      <button class="bg-red-50 hover:bg-red-100 text-red-700 font-semibold px-4 py-2 rounded-lg text-sm">Delete</button>
    </form>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-1 bg-white rounded-xl shadow-sm border border-slate-200 p-5">
    <h3 class="font-bold text-slate-900 mb-3">Contact Details</h3>
    <dl class="text-sm space-y-2">
      <div class="flex justify-between gap-3"><dt class="text-slate-500">Phone</dt><dd class="font-medium text-slate-900 text-right"><%= borrower.phone || '—' %></dd></div>
      <div class="flex justify-between gap-3"><dt class="text-slate-500">Email</dt><dd class="font-medium text-slate-900 text-right truncate"><%= borrower.email || '—' %></dd></div>
      <div class="flex justify-between gap-3"><dt class="text-slate-500">Address</dt><dd class="font-medium text-slate-900 text-right"><%= borrower.address || '—' %></dd></div>
      <div class="flex justify-between gap-3"><dt class="text-slate-500">ID Number</dt><dd class="font-medium text-slate-900 text-right"><%= borrower.id_number || '—' %></dd></div>
      <div class="flex justify-between gap-3"><dt class="text-slate-500">Added</dt><dd class="font-medium text-slate-900 text-right"><%= fmt.date(borrower.created_at) %></dd></div>
    </dl>
    <% if (borrower.notes) { %>
      <div class="mt-4 pt-4 border-t border-slate-100">
        <h4 class="text-xs font-bold uppercase tracking-wider text-slate-500 mb-1">Notes</h4>
        <p class="text-sm text-slate-700 whitespace-pre-wrap"><%= borrower.notes %></p>
      </div>
    <% } %>
  </div>

  <div class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-slate-200">
    <div class="px-5 py-4 border-b border-slate-200 flex items-center justify-between">
      <h3 class="font-bold text-slate-900">Loan History (<%= loans.length %>)</h3>
    </div>
    <% if (loans.length === 0) { %>
      <div class="p-8 text-center text-slate-500 text-sm">No loans yet. <a href="/loans/new?borrower_id=<%= borrower.id %>" class="text-brand-600 font-semibold">Create the first one →</a></div>
    <% } else { %>
      <ul class="divide-y divide-slate-100">
        <% loans.forEach(l => { %>
          <li class="px-5 py-4">
            <div class="flex items-start justify-between gap-3">
              <div class="flex-1 min-w-0">
                <a href="/loans/<%= l.id %>" class="font-semibold text-slate-900 hover:text-brand-600">Loan #<%= l.id %> · <%= fmt.money(l.principal) %></a>
                <div class="text-xs text-slate-500 mt-0.5">
                  <%= fmt.date(l.start_date) %> → <%= fmt.date(l.end_date) %> · <%= l.term_days %>d · daily <%= fmt.money(l.daily_payment) %>
                </div>
              </div>
              <div class="text-right flex-shrink-0">
                <% if (l.status === 'active') { %>
                  <span class="inline-block text-[10px] font-bold uppercase px-2 py-0.5 rounded <%= l.progress.overdue ? 'bg-red-100 text-red-700' : 'bg-brand-100 text-brand-800' %>"><%= l.progress.overdue ? 'Overdue' : 'Active' %></span>
                <% } else if (l.status === 'completed') { %>
                  <span class="inline-block text-[10px] font-bold uppercase px-2 py-0.5 rounded bg-emerald-100 text-emerald-700">Paid</span>
                <% } else { %>
                  <span class="inline-block text-[10px] font-bold uppercase px-2 py-0.5 rounded bg-slate-200 text-slate-700"><%= l.status %></span>
                <% } %>
                <div class="text-xs text-slate-500 mt-1"><%= fmt.money(l.progress.balance) %> balance</div>
              </div>
            </div>
            <div class="mt-2 h-1.5 bg-slate-100 rounded-full overflow-hidden">
              <div class="h-full bg-brand-500 rounded-full" style="width: <%= l.progress.percentPaid %>%"></div>
            </div>
          </li>
        <% }); %>
      </ul>
    <% } %>
  </div>
</div>
