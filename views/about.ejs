<!-- Hero -->
<div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden mb-6">
  <div class="bg-gradient-to-br from-brand-50 to-white px-6 py-10 sm:px-10 sm:py-14 text-center">
    <span class="relative inline-flex items-center justify-center mb-4">
      <img src="/img/logo-horizontal.png" alt="Golden Crest Finance" class="h-20 sm:h-28 w-auto object-contain" onerror="this.style.display='none';this.nextElementSibling.style.display='inline-flex'">
      <span style="display:none" class="items-center gap-3">
        <span class="w-14 h-14 rounded-xl bg-gradient-to-br from-brand-300 to-brand-500 text-ink flex items-center justify-center font-extrabold text-xl">GC</span>
        <span class="text-3xl font-extrabold text-ink tracking-tight">GOLDEN CREST <span class="font-light text-brand-600">FINANCE</span></span>
      </span>
    </span>
    <p class="text-slate-600 text-sm sm:text-base max-w-xl mx-auto">Lending made simple — fair, fast, and built for everyday Filipinos.</p>
  </div>
</div>

<!-- CEO -->
<div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden mb-6">
  <div class="grid grid-cols-1 md:grid-cols-3">
    <div class="md:col-span-1 bg-slate-50 flex items-center justify-center p-6">
      <div class="relative">
        <img src="/img/ceo-marvin.jpg" alt="Marvin Dionaldo Trinidad" class="w-48 h-48 sm:w-56 sm:h-56 rounded-2xl object-cover shadow-lg ring-4 ring-white" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
        <div style="display:none" class="w-48 h-48 sm:w-56 sm:h-56 rounded-2xl bg-gradient-to-br from-brand-400 to-brand-600 text-ink items-center justify-center text-5xl font-extrabold shadow-lg ring-4 ring-white">MT</div>
      </div>
    </div>
    <div class="md:col-span-2 p-6 sm:p-8">
      <div class="text-xs font-bold uppercase tracking-wider text-brand-600">Leadership</div>
      <h1 class="text-2xl sm:text-3xl font-extrabold text-ink mt-1">Marvin Dionaldo Trinidad</h1>
      <div class="text-sm font-semibold text-slate-500 mt-0.5">President &amp; Chief Executive Officer</div>
      <div class="mt-4 space-y-3 text-sm text-slate-600 leading-relaxed">
        <p>
          Marvin Dionaldo Trinidad founded Golden Crest Finance with a simple belief: access to
          fair, transparent credit should be within everyone's reach. Under his leadership, the
          company provides accessible daily-collection loans designed around how real people earn
          and pay.
        </p>
        <p>
          As President &amp; CEO, Marvin oversees the company's lending operations, ensuring every
          borrower is treated with respect and every transaction is clear and honest — values that
          remain at the heart of Golden Crest Finance.
        </p>
      </div>
      <div class="mt-5 flex flex-wrap gap-2">
        <span class="inline-flex items-center gap-1.5 bg-brand-50 text-brand-700 text-xs font-semibold px-3 py-1.5 rounded-full border border-brand-200">Founder</span>
        <span class="inline-flex items-center gap-1.5 bg-brand-50 text-brand-700 text-xs font-semibold px-3 py-1.5 rounded-full border border-brand-200">President &amp; CEO</span>
        <span class="inline-flex items-center gap-1.5 bg-brand-50 text-brand-700 text-xs font-semibold px-3 py-1.5 rounded-full border border-brand-200">Golden Crest Finance</span>
      </div>
    </div>
  </div>
</div>

<!-- Company info -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
  <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
    <div class="w-11 h-11 rounded-xl bg-brand-100 text-brand-700 flex items-center justify-center mb-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
    </div>
    <h3 class="font-bold text-ink">Fast &amp; Simple</h3>
    <p class="text-sm text-slate-600 mt-1">Quick loan processing with a clear daily payment schedule — no hidden surprises.</p>
  </div>
  <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
    <div class="w-11 h-11 rounded-xl bg-brand-100 text-brand-700 flex items-center justify-center mb-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    </div>
    <h3 class="font-bold text-ink">Transparent Terms</h3>
    <p class="text-sm text-slate-600 mt-1">A straightforward <strong>10% monthly interest</strong> with convenient daily collection.</p>
  </div>
  <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
    <div class="w-11 h-11 rounded-xl bg-brand-100 text-brand-700 flex items-center justify-center mb-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
    </div>
    <h3 class="font-bold text-ink">People First</h3>
    <p class="text-sm text-slate-600 mt-1">Every borrower is treated with respect — credit built around real lives and livelihoods.</p>
  </div>
</div>

<!-- Brand kit -->
<div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 sm:p-8 mb-6">
  <div class="text-xs font-bold uppercase tracking-wider text-brand-600">Our Brand</div>
  <h2 class="text-xl font-extrabold text-ink mt-1 mb-5">Golden Crest Finance Identity</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div class="border border-slate-200 rounded-xl p-6 flex flex-col items-center justify-center bg-white min-h-[140px]">
      <img src="/img/logo-horizontal.png" alt="Primary logo" class="max-h-20 w-auto object-contain" onerror="this.style.display='none';this.nextElementSibling.style.display='block'">
      <span style="display:none" class="text-slate-400 text-sm">Primary logo (horizontal)</span>
      <span class="mt-3 text-[11px] font-bold uppercase tracking-wider text-slate-400">Primary Logo</span>
    </div>
    <div class="border border-slate-200 rounded-xl p-6 flex flex-col items-center justify-center bg-white min-h-[140px]">
      <img src="/img/gc-icon.png" alt="Icon mark" class="max-h-24 w-auto object-contain" onerror="this.style.display='none';this.nextElementSibling.style.display='block'">
      <span style="display:none" class="text-slate-400 text-sm">GC icon mark</span>
      <span class="mt-3 text-[11px] font-bold uppercase tracking-wider text-slate-400">Icon Mark</span>
    </div>
  </div>
  <div class="mt-5">
    <div class="text-xs font-bold uppercase tracking-wider text-slate-500 mb-2">Brand Colors</div>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <% const swatches = [['#DA8850','Gold'],['#898544','Olive'],['#054E5F','Ink Teal'],['#00337C','Royal']]; %>
      <% swatches.forEach(([hex, name]) => { %>
        <div class="rounded-xl overflow-hidden border border-slate-200">
          <div style="background: <%= hex %>; height: 56px;"></div>
          <div class="px-3 py-2">
            <div class="text-xs font-bold text-ink"><%= name %></div>
            <div class="text-[11px] text-slate-500"><%= hex %></div>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
</div>

<!-- CTA -->
<div class="bg-gradient-to-br from-brand-300 to-brand-500 rounded-2xl shadow-lg p-6 sm:p-8 text-ink text-center">
  <h2 class="text-xl sm:text-2xl font-extrabold">Ready to get started?</h2>
  <p class="text-sm mt-1 opacity-80 max-w-lg mx-auto">Estimate your daily payment with our free calculator, or sign in to manage loans and collections.</p>
  <div class="mt-5 flex flex-wrap gap-2 justify-center">
    <a href="/calculator" class="bg-ink text-white font-semibold px-5 py-2.5 rounded-lg text-sm hover:bg-ink-700">Try the Calculator</a>
    <% if (typeof currentUser !== 'undefined' && currentUser) { %>
      <a href="/" class="bg-white/90 text-ink font-semibold px-5 py-2.5 rounded-lg text-sm hover:bg-white">Go to Dashboard</a>
    <% } else { %>
      <a href="/login" class="bg-white/90 text-ink font-semibold px-5 py-2.5 rounded-lg text-sm hover:bg-white">Sign In</a>
    <% } %>
  </div>
</div>
