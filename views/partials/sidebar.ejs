<% const nav = [
  { href: '/', label: 'Dashboard', icon: 'M3 12l9-9 9 9M5 10v10h14V10' },
  { href: '/borrowers', label: 'Borrowers', icon: 'M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-5a4 4 0 11-8 0 4 4 0 018 0zm6 0a4 4 0 11-8 0 4 4 0 018 0z' },
  { href: '/loans', label: 'Loans', icon: 'M3 10h18M3 6h18M3 14h18M3 18h18' },
  { href: '/payments', label: 'Collections', peso: true },
  { href: '/reports', label: 'Reports', icon: 'M9 17v-6h13M9 17l-4-4m4 4l-4 4M3 3h13v6' },
  { href: '/income', label: 'Income', icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
  { href: '/print/cards', label: 'Print Cards', icon: 'M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z' },
  { href: '/calculator', label: 'Calculator', icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z' },
  { href: '/about', label: 'About', icon: 'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z' }
]; %>

<aside id="sidebar" class="hidden lg:flex fixed inset-y-0 top-16 left-0 w-64 bg-white border-r border-slate-200 z-20 flex-col">
  <nav class="flex-1 p-4 space-y-1">
    <% nav.forEach(item => {
       const isActive = item.href === '/' ? path === '/' : path.indexOf(item.href) === 0;
    %>
      <a href="<%= item.href %>" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium <%= isActive ? 'bg-brand-500 text-ink shadow-sm' : 'text-slate-700 hover:bg-slate-100' %>">
        <% if (item.peso) { %>
          <span class="h-5 w-5 flex-shrink-0 flex items-center justify-center text-lg font-extrabold leading-none">₱</span>
        <% } else { %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= item.icon %>"/>
          </svg>
        <% } %>
        <span><%= item.label %></span>
      </a>
    <% }); %>
  </nav>
  <div class="p-4 border-t border-slate-200">
    <div class="rounded-lg bg-gradient-to-br from-brand-300 to-brand-500 p-4 text-ink">
      <div class="text-xs font-bold uppercase tracking-wider opacity-75">Loan Terms</div>
      <div class="mt-1 text-2xl font-extrabold">10% / month</div>
      <div class="text-xs opacity-75">Daily collection</div>
    </div>
  </div>
</aside>

<!-- Mobile sidebar drawer -->
<div id="mobileSidebar" class="fixed inset-0 z-40 hidden lg:hidden">
  <div class="absolute inset-0 bg-ink/70" data-close-sidebar></div>
  <div class="absolute inset-y-0 left-0 w-72 bg-white shadow-xl flex flex-col">
    <div class="h-16 px-4 flex items-center justify-between border-b border-slate-200 bg-ink text-white">
      <span class="font-bold">Menu</span>
      <button data-close-sidebar class="p-2 rounded hover:bg-ink-700">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <nav class="flex-1 p-4 space-y-1 overflow-y-auto">
      <% nav.forEach(item => {
         const isActive = item.href === '/' ? path === '/' : path.indexOf(item.href) === 0;
      %>
        <a href="<%= item.href %>" class="flex items-center gap-3 px-3 py-3 rounded-lg text-sm font-medium <%= isActive ? 'bg-brand-500 text-ink' : 'text-slate-700 hover:bg-slate-100' %>">
          <% if (item.peso) { %>
            <span class="h-5 w-5 flex items-center justify-center text-lg font-extrabold leading-none">₱</span>
          <% } else { %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= item.icon %>"/></svg>
          <% } %>
          <span><%= item.label %></span>
        </a>
      <% }); %>
    </nav>
  </div>
</div>
