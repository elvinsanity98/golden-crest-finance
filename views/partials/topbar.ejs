<header class="bg-ink text-white sticky top-0 z-30 shadow-lg">
  <div class="flex items-center justify-between px-4 sm:px-6 lg:px-8 h-16">
    <div class="flex items-center gap-3">
      <button id="sidebarToggle" class="lg:hidden p-2 -ml-2 rounded hover:bg-ink-700" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <a href="/" class="flex items-center gap-2">
        <span class="relative w-9 h-9 flex-shrink-0 block rounded-lg bg-white shadow-sm p-0.5">
          <img src="/img/gc-icon.png" alt="Golden Crest Finance" class="w-full h-full object-contain" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
          <span style="display:none" class="absolute inset-0 bg-gradient-to-br from-brand-300 to-brand-500 text-ink rounded-lg items-center justify-center font-extrabold">GC</span>
        </span>
        <div class="hidden sm:block leading-tight">
          <div class="font-bold text-base"><%= brand.name %></div>
          <div class="text-[10px] uppercase tracking-wider text-brand-300">10% / month · Daily</div>
        </div>
      </a>
    </div>
    <div class="flex items-center gap-2">
      <% if (typeof currentUser !== 'undefined' && currentUser) { %>
        <div class="text-right hidden sm:block leading-tight">
          <div class="text-sm font-semibold"><%= currentUser.fullName %></div>
          <div class="text-[10px] uppercase tracking-wider text-slate-400"><%= currentUser.role %></div>
        </div>
        <form action="/logout" method="POST" data-confirm="Log out of Golden Crest Finance?" class="ml-1">
          <button class="px-3 py-1.5 text-sm rounded-md bg-ink-800 hover:bg-ink-700 border border-ink-700">Logout</button>
        </form>
      <% } else { %>
        <a href="/login" class="px-3 py-1.5 text-sm rounded-md bg-brand-500 hover:bg-brand-400 text-ink font-semibold">Login</a>
      <% } %>
    </div>
  </div>
</header>
