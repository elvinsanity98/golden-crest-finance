<div class="mb-6 flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
  <div>
    <div class="text-xs font-bold uppercase tracking-wider text-brand-600">Loan Details</div>
    <h1 class="text-2xl sm:text-3xl font-extrabold text-slate-900">Loan #<%= loan.id %></h1>
    <div class="text-sm text-slate-600 mt-1">
      <a href="/borrowers/<%= loan.borrower_id %>" class="font-semibold text-slate-900 hover:text-brand-600"><%= loan.borrower_name %></a>
      <% if (loan.borrower_phone) { %> · <%= loan.borrower_phone %><% } %>
    </div>
  </div>
  <div class="flex flex-wrap gap-2">
    <% if (loan.status === 'active') { %>
      <form action="/loans/<%= loan.id %>/close" method="POST">
        <input type="hidden" name="status" value="completed">
        <button class="bg-emerald-50 hover:bg-emerald-100 text-emerald-700 font-semibold px-4 py-2 rounded-lg text-sm" onclick="return confirm('Mark this loan as fully paid?');">Mark Paid</button>
      </form>
      <form action="/loans/<%= loan.id %>/close" method="POST">
        <input type="hidden" name="status" value="defaulted">
        <button class="bg-amber-50 hover:bg-amber-100 text-amber-700 font-semibold px-4 py-2 rounded-lg text-sm" onclick="return confirm('Mark this loan as defaulted?');">Mark Defaulted</button>
      </form>
    <% } else { %>
      <form action="/loans/<%= loan.id %>/reopen" method="POST">
        <button class="bg-slate-200 hover:bg-slate-300 text-slate-700 font-semibold px-4 py-2 rounded-lg text-sm">Reopen</button>
      </form>
    <% } %>
    <form action="/loans/<%= loan.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this loan and ALL its payments?');">
      <button class="bg-red-50 hover:bg-red-100 text-red-700 font-semibold px-4 py-2 rounded-lg text-sm">Delete</button>
    </form>
  </div>
</div>

<!-- KPIs -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
  <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4">
    <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Principal</div>
    <div class="mt-2 text-xl font-extrabold text-slate-900"><%= fmt.money(loan.principal) %></div>
  </div>
  <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4">
    <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Total Payable</div>
    <div class="mt-2 text-xl font-extrabold text-slate-900"><%= fmt.money(loan.total_payable) %></div>
    <div class="text-xs text-slate-500">Interest <%= fmt.money(loan.total_interest) %></div>
  </div>
  <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4">
    <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Paid</div>
    <div class="mt-2 text-xl font-extrabold text-emerald-600"><%= fmt.money(totalPaid) %></div>
    <div class="text-xs text-slate-500"><%= progress.percentPaid.toFixed(0) %>% of total</div>
  </div>
  <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4">
    <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Balance</div>
    <div class="mt-2 text-xl font-extrabold <%= progress.balance > 0 ? 'text-slate-900' : 'text-emerald-600' %>"><%= fmt.money(progress.balance) %></div>
    <% if (progress.arrears > 0) { %><div class="text-xs text-red-600 font-semibold">Arrears <%= fmt.money(progress.arrears) %></div><% } %>
  </div>
</div>

<!-- Progress bar -->
<div class="bg-white rounded-xl shadow-sm border border-slate-200 p-5 mb-6">
  <div class="flex items-center justify-between mb-2 text-sm">
    <div class="font-semibold text-slate-900">Payment progress</div>
    <div class="text-slate-500"><%= progress.percentPaid.toFixed(1) %>%</div>
  </div>
  <div class="h-3 bg-slate-100 rounded-full overflow-hidden">
    <div class="h-full bg-gradient-to-r from-brand-400 to-brand-600 rounded-full transition-all" style="width: <%= progress.percentPaid %>%"></div>
  </div>
  <div class="grid grid-cols-3 gap-2 mt-4 text-center text-xs">
    <div><div class="font-bold text-slate-900"><%= progress.elapsed %> / <%= loan.term_days %></div><div class="text-slate-500">Days elapsed</div></div>
    <div><div class="font-bold text-slate-900"><%= progress.daysRemaining %></div><div class="text-slate-500">Days remaining</div></div>
    <div><div class="font-bold text-slate-900"><%= fmt.money(loan.daily_payment) %></div><div class="text-slate-500">Daily target</div></div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

  <!-- Record payment -->
  <% if (loan.status === 'active') { %>
  <div class="lg:col-span-1 bg-gradient-to-br from-slate-900 to-slate-800 rounded-xl shadow-lg p-5 sm:p-6 text-white h-fit">
    <div class="text-xs font-bold uppercase tracking-wider text-brand-300">Record Payment</div>
    <h3 class="text-lg font-bold mt-1 mb-4">Daily Collection</h3>
    <form action="/payments" method="POST" class="space-y-3">
      <input type="hidden" name="loan_id" value="<%= loan.id %>">
      <div>
        <label class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-1">Amount</label>
        <input name="amount" type="number" step="0.01" min="0.01" required value="<%= loan.daily_payment %>" class="w-full rounded-lg bg-slate-700 border border-slate-600 text-white px-3 py-2 focus:ring-2 focus:ring-brand-500">
      </div>
      <div>
        <label class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-1">Date</label>
        <input name="payment_date" type="date" value="<%= todayStr %>" class="w-full rounded-lg bg-slate-700 border border-slate-600 text-white px-3 py-2 focus:ring-2 focus:ring-brand-500">
      </div>
      <div>
        <label class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-1">Method</label>
        <select name="method" class="w-full rounded-lg bg-slate-700 border border-slate-600 text-white px-3 py-2 focus:ring-2 focus:ring-brand-500">
          <option value="cash">Cash</option>
          <option value="gcash">GCash</option>
          <option value="bank">Bank Transfer</option>
          <option value="maya">Maya</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div>
        <label class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-1">Notes</label>
        <input name="notes" placeholder="optional" class="w-full rounded-lg bg-slate-700 border border-slate-600 text-white px-3 py-2 focus:ring-2 focus:ring-brand-500">
      </div>
      <button class="w-full bg-brand-500 hover:bg-brand-400 text-slate-900 font-bold py-2.5 rounded-lg shadow">Record Payment</button>
    </form>
  </div>
  <% } %>

  <!-- Payments list -->
  <div class="<%= loan.status === 'active' ? 'lg:col-span-2' : 'lg:col-span-3' %> bg-white rounded-xl shadow-sm border border-slate-200">
    <div class="px-5 py-4 border-b border-slate-200 flex items-center justify-between">
      <h3 class="font-bold text-slate-900">Payment History (<%= payments.length %>)</h3>
    </div>
    <% if (payments.length === 0) { %>
      <div class="p-8 text-center text-slate-500 text-sm">No payments yet.</div>
    <% } else { %>
      <ul class="divide-y divide-slate-100">
        <% payments.forEach(p => { %>
          <li class="px-5 py-3 flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-emerald-100 text-emerald-700 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="font-semibold text-slate-900"><%= fmt.money(p.amount) %></div>
              <div class="text-xs text-slate-500">
                <%= fmt.date(p.payment_date) %> · <%= p.method %><% if (p.collected_by) { %> · by <%= p.collected_by %><% } %>
                <% if (p.notes) { %> · <span class="italic"><%= p.notes %></span><% } %>
              </div>
            </div>
            <form action="/payments/<%= p.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this payment?');">
              <button class="text-xs text-red-600 hover:text-red-700 font-semibold">Delete</button>
            </form>
          </li>
        <% }); %>
      </ul>
    <% } %>
  </div>
</div>

<!-- Daily schedule -->
<div class="bg-white rounded-xl shadow-sm border border-slate-200 mt-6">
  <div class="px-5 py-4 border-b border-slate-200">
    <h3 class="font-bold text-slate-900">Daily Collection Schedule</h3>
    <p class="text-xs text-slate-500 mt-0.5">Term: <%= fmt.date(loan.start_date) %> → <%= fmt.date(loan.end_date) %> (<%= loan.term_days %> days)</p>
  </div>
  <div class="p-3 sm:p-5">
    <div class="grid grid-cols-7 sm:grid-cols-10 md:grid-cols-14 lg:grid-cols-15 gap-1">
      <% schedule.forEach(s => {
        var status;
        if (s.paid >= s.expected) status = 'paid';
        else if (s.paid > 0) status = 'partial';
        else if (s.date < todayStr) status = 'missed';
        else if (s.date === todayStr) status = 'today';
        else status = 'future';
        var cls = ({
          paid: 'bg-emerald-500 text-white',
          partial: 'bg-amber-400 text-slate-900',
          missed: 'bg-red-200 text-red-800',
          today: 'bg-brand-500 text-slate-900 ring-2 ring-brand-300',
          future: 'bg-slate-100 text-slate-500'
        })[status];
      %>
        <div class="<%= cls %> aspect-square rounded text-[10px] flex items-center justify-center font-bold cursor-help" title="Day <%= s.day %> · <%= s.date %> · Paid <%= fmt.money(s.paid) %> of <%= fmt.money(s.expected) %>">
          <%= s.day %>
        </div>
      <% }); %>
    </div>
    <div class="mt-4 flex flex-wrap gap-3 text-xs text-slate-600">
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-emerald-500"></span> Paid</span>
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-amber-400"></span> Partial</span>
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-red-200"></span> Missed</span>
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-brand-500"></span> Today</span>
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-slate-200"></span> Future</span>
    </div>
  </div>
</div>
