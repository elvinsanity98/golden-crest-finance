<%- include('../partials/page-header', { heading: 'Loans', eyebrow: 'Portfolio', subtitle: 'All loans tracked by status.', actions: '<a href="/loans/new" class="bg-brand-500 hover:bg-brand-400 text-slate-900 font-semibold px-4 py-2 rounded-lg text-sm shadow">+ New Loan</a>' }) %>

<% const qstr = q ? '&q=' + encodeURIComponent(q) : ''; %>

<form method="GET" class="mb-4">
  <input type="hidden" name="status" value="<%= status %>">
  <div class="relative">
    <input name="q" value="<%= q %>" placeholder="Search loans by borrower name, loan #, or purpose..." class="w-full pl-10 pr-24 py-2.5 rounded-lg border border-slate-300 focus:ring-2 focus:ring-brand-500 focus:border-transparent text-sm">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 absolute left-3 top-2.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
    <div class="absolute right-1.5 top-1.5 flex gap-1">
      <% if (q) { %>
        <a href="/loans?status=<%= status %>" class="px-2 py-1 text-xs font-semibold text-slate-500 hover:text-slate-700 rounded-md hover:bg-slate-100 flex items-center">Clear</a>
      <% } %>
      <button class="bg-ink hover:bg-ink-700 text-white text-xs font-semibold px-3 py-1.5 rounded-md">Search</button>
    </div>
  </div>
</form>

<div class="flex gap-2 mb-4 overflow-x-auto pb-1">
  <% const tabs = [['active','Active'],['completed','Paid'],['defaulted','Defaulted'],['all','All']]; %>
  <% tabs.forEach(([k, label]) => { %>
    <a href="/loans?status=<%= k %><%= qstr %>" class="px-3 py-1.5 rounded-lg text-xs font-bold uppercase tracking-wider whitespace-nowrap <%= status === k ? 'bg-ink text-white' : 'bg-white text-slate-600 border border-slate-200 hover:bg-slate-50' %>"><%= label %></a>
  <% }); %>
</div>

<% if (q) { %>
  <p class="text-sm text-slate-500 mb-3"><%= loans.length %> result<%= loans.length === 1 ? '' : 's' %> for "<span class="font-semibold text-slate-700"><%= q %></span>"<%= status !== 'all' ? ' in ' + status : '' %></p>
<% } %>

<% if (loans.length === 0) { %>
  <div class="bg-white rounded-xl shadow-sm border border-slate-200">
    <% if (q) { %>
      <%- include('../partials/empty', {
        icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
        title: 'No loans match your search',
        message: 'Try a different borrower name, loan number, or purpose.'
      }) %>
    <% } else { %>
      <%- include('../partials/empty', {
        icon: 'M3 10h18M3 6h18M3 14h18M3 18h18',
        title: 'No ' + (status === 'all' ? '' : status + ' ') + 'loans',
        message: status === 'active' ? 'Create a loan to start a daily collection schedule.' : 'Nothing to show under this filter.',
        actionHref: status === 'active' ? '/loans/new' : '',
        actionLabel: '+ New Loan'
      }) %>
    <% } %>
  </div>
<% } else { %>
  <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
    <div class="hidden md:block overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-slate-50 text-xs font-bold uppercase tracking-wider text-slate-500">
          <tr>
            <th class="px-5 py-3 text-left">Borrower</th>
            <th class="px-5 py-3 text-right">Principal</th>
            <th class="px-5 py-3 text-right">Total Payable</th>
            <th class="px-5 py-3 text-right">Daily</th>
            <th class="px-5 py-3 text-right">Balance</th>
            <th class="px-5 py-3 text-left">Term</th>
            <th class="px-5 py-3 text-center">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% loans.forEach(l => { %>
            <tr class="hover:bg-slate-50 cursor-pointer" onclick="location.href='/loans/<%= l.id %>'">
              <td class="px-5 py-3">
                <div class="font-semibold text-slate-900"><%= l.borrower_name %></div>
                <div class="text-xs text-slate-500">Loan #<%= l.id %></div>
              </td>
              <td class="px-5 py-3 text-right font-medium"><%= fmt.money(l.principal) %></td>
              <td class="px-5 py-3 text-right font-medium"><%= fmt.money(l.total_payable) %></td>
              <td class="px-5 py-3 text-right font-medium"><%= fmt.money(l.daily_payment) %></td>
              <td class="px-5 py-3 text-right font-bold <%= l.progress.balance > 0 ? 'text-slate-900' : 'text-emerald-600' %>"><%= fmt.money(l.progress.balance) %></td>
              <td class="px-5 py-3 text-xs text-slate-500"><%= fmt.date(l.start_date) %><br>→ <%= fmt.date(l.end_date) %></td>
              <td class="px-5 py-3 text-center">
                <% if (l.status === 'active') {
                     var s, c;
                     if (l.progress.scheduled) { s = 'Scheduled'; c = 'bg-blue-100 text-blue-700'; }
                     else if (l.progress.overdue) { s = 'Overdue'; c = 'bg-red-100 text-red-700'; }
                     else if (l.progress.arrears > 0) { s = 'Arrears'; c = 'bg-amber-100 text-amber-700'; }
                     else { s = 'Active'; c = 'bg-brand-100 text-brand-800'; }
                %>
                  <span class="inline-block text-[10px] font-bold uppercase px-2 py-0.5 rounded <%= c %>"><%= s %></span>
                <% } else if (l.status === 'completed') { %>
                  <span class="inline-block text-[10px] font-bold uppercase px-2 py-0.5 rounded bg-emerald-100 text-emerald-700">Paid</span>
                <% } else { %>
                  <span class="inline-block text-[10px] font-bold uppercase px-2 py-0.5 rounded bg-slate-200 text-slate-700"><%= l.status %></span>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <ul class="md:hidden divide-y divide-slate-100">
      <% loans.forEach(l => { %>
        <li>
          <a href="/loans/<%= l.id %>" class="block px-4 py-3 hover:bg-slate-50">
            <div class="flex items-center justify-between gap-2">
              <div class="font-semibold text-slate-900 truncate"><%= l.borrower_name %></div>
              <span class="text-sm font-bold"><%= fmt.money(l.progress.balance) %></span>
            </div>
            <div class="text-xs text-slate-500 mt-1 flex items-center justify-between">
              <span>#<%= l.id %> · daily <%= fmt.money(l.daily_payment) %></span>
              <% if (l.status === 'active') {
                   var ms, mc;
                   if (l.progress.scheduled) { ms = 'Scheduled'; mc = 'bg-blue-100 text-blue-700'; }
                   else if (l.progress.overdue) { ms = 'Overdue'; mc = 'bg-red-100 text-red-700'; }
                   else if (l.progress.arrears > 0) { ms = 'Arrears'; mc = 'bg-amber-100 text-amber-700'; }
                   else { ms = 'Active'; mc = 'bg-brand-100 text-brand-800'; }
              %>
                <span class="text-[10px] font-bold uppercase px-2 py-0.5 rounded <%= mc %>"><%= ms %></span>
              <% } else if (l.status === 'completed') { %>
                <span class="text-[10px] font-bold uppercase px-2 py-0.5 rounded bg-emerald-100 text-emerald-700">Paid</span>
              <% } else { %>
                <span class="text-[10px] font-bold uppercase px-2 py-0.5 rounded bg-slate-200 text-slate-700"><%= l.status %></span>
              <% } %>
            </div>
            <div class="mt-2 h-1 bg-slate-100 rounded-full overflow-hidden">
              <div class="h-full bg-brand-500" style="width: <%= l.progress.percentPaid %>%"></div>
            </div>
          </a>
        </li>
      <% }); %>
    </ul>
  </div>
<% } %>
