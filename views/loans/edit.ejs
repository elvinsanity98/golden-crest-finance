<%- include('../partials/page-header', { heading: 'Edit Loan #' + loan.id, eyebrow: 'Loan Terms', subtitle: loan.borrower_name + ' — change the term, mode of payment, or amounts. Totals recompute automatically.' }) %>

<% if (errors) { %>
  <div class="mb-4 rounded-lg px-4 py-3 text-sm bg-red-50 text-red-800 border border-red-200"><%= errors %></div>
<% } %>

<% if (paymentCount > 0) { %>
  <div class="mb-4 rounded-lg px-4 py-3 text-sm bg-amber-50 text-amber-800 border border-amber-200">
    <strong>Heads up:</strong> this loan already has <%= paymentCount %> payment(s) totaling <%= fmt.money(totalPaid) %>.
    Changing the terms recomputes interest, total payable, and the installment — recorded payments stay untouched
    and count toward the new total.
  </div>
<% } %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <form method="POST" action="/loans/<%= loan.id %>?_method=PUT" data-confirm="Save these new terms? Totals and the schedule will be recalculated." class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-slate-200 p-5 sm:p-6 space-y-4">
    <div>
      <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">Borrower</label>
      <div class="w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-slate-700 font-semibold"><%= loan.borrower_name %></div>
    </div>

    <%- include('_form-fields', { form }) %>

    <div class="flex gap-2 pt-2">
      <button class="bg-brand-500 hover:bg-brand-400 text-ink font-bold px-5 py-2.5 rounded-lg shadow text-sm">Save New Terms</button>
      <a href="/loans/<%= loan.id %>" class="bg-slate-200 hover:bg-slate-300 text-slate-700 font-semibold px-5 py-2.5 rounded-lg text-sm">Cancel</a>
    </div>
  </form>

  <%- include('_preview') %>
</div>
