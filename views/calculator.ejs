<%- include('partials/page-header', { heading: 'Loan Calculator', eyebrow: 'Helper Tool', subtitle: 'Estimate daily payments before signing — free and available without login.' }) %>

<div class="grid grid-cols-1 lg:grid-cols-5 gap-6">
  <form method="GET" class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-slate-200 p-5 sm:p-6 space-y-4 h-fit">
    <div>
      <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">Loan Amount (₱)</label>
      <input name="principal" type="number" step="0.01" min="1" value="<%= form.principal %>" placeholder="e.g. 10000" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:ring-2 focus:ring-brand-500 focus:border-transparent">
    </div>
    <div>
      <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">Term (Days)</label>
      <input name="term_days" type="number" min="1" value="<%= form.term_days %>" placeholder="e.g. 30, 60, 90" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      <div class="mt-2 flex flex-wrap gap-2">
        <% [15, 30, 60, 90, 120].forEach(d => { %>
          <button type="submit" formnovalidate name="term_days" value="<%= d %>" class="text-xs px-2.5 py-1 bg-slate-100 hover:bg-slate-200 rounded font-semibold text-slate-700"><%= d %>d</button>
        <% }); %>
      </div>
    </div>
    <div>
      <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">Mode of Payment</label>
      <select name="frequency" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        <option value="daily" <%= form.frequency === 'daily' ? 'selected' : '' %>>Daily</option>
        <option value="weekly" <%= form.frequency === 'weekly' ? 'selected' : '' %>>Weekly</option>
        <option value="monthly" <%= form.frequency === 'monthly' ? 'selected' : '' %>>Monthly</option>
      </select>
    </div>
    <div>
      <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">Monthly Interest (%)</label>
      <input name="monthly_rate" type="number" step="0.01" min="0" value="<%= form.monthly_rate %>" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      <p class="text-xs text-slate-500 mt-1">Default 10% / month.</p>
    </div>
    <div>
      <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">First Payment Date</label>
      <input name="start_date" type="date" value="<%= form.start_date %>" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:ring-2 focus:ring-brand-500 focus:border-transparent">
    </div>
    <button class="w-full bg-brand-500 hover:bg-brand-400 text-slate-900 font-bold py-2.5 rounded-lg shadow text-sm">Calculate</button>
  </form>

  <div class="lg:col-span-3 space-y-4">
    <% if (error) { %>
      <div class="rounded-lg px-4 py-3 text-sm bg-red-50 text-red-800 border border-red-200"><%= error %></div>
    <% } %>

    <% if (result) { %>
      <div class="bg-gradient-to-br from-ink to-ink-900 rounded-xl shadow-lg p-5 sm:p-6 text-white">
        <div class="text-xs font-bold uppercase tracking-wider text-brand-300">Estimated</div>
        <h3 class="text-lg font-bold mt-1 mb-4">Loan Breakdown</h3>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          <div>
            <div class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Principal</div>
            <div class="mt-1 text-lg font-extrabold"><%= fmt.money(result.principal) %></div>
          </div>
          <div>
            <div class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Interest</div>
            <div class="mt-1 text-lg font-extrabold"><%= fmt.money(result.totalInterest) %></div>
          </div>
          <div>
            <div class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Total Payable</div>
            <div class="mt-1 text-lg font-extrabold text-brand-400"><%= fmt.money(result.totalPayable) %></div>
          </div>
          <div>
            <div class="text-[10px] font-bold uppercase tracking-wider text-slate-400"><%= result.frequency === 'weekly' ? 'Weekly' : result.frequency === 'monthly' ? 'Monthly' : 'Daily' %> Payment</div>
            <div class="mt-1 text-2xl font-extrabold text-brand-300"><%= fmt.money(result.installment) %></div>
          </div>
        </div>
        <p class="mt-4 text-xs text-slate-400">
          For <%= result.termDays %> days at <%= result.monthlyRate %>% / month.
          Interest = <%= fmt.money(result.principal) %> × <%= result.monthlyRate %>% × (<%= result.termDays %>/30) = <%= fmt.money(result.totalInterest) %>.
        </p>
      </div>

      <% if (schedule) { %>
        <div class="bg-white rounded-xl shadow-sm border border-slate-200">
          <div class="px-5 py-4 border-b border-slate-200">
            <h3 class="font-bold text-slate-900">Payment Schedule</h3>
            <p class="text-xs text-slate-500 mt-0.5">Pay <span class="font-semibold text-slate-700"><%= fmt.money(result.installment) %></span> every <%= result.frequency === 'weekly' ? 'week' : result.frequency === 'monthly' ? 'month' : 'day' %> — <%= result.periods %> payment<%= result.periods === 1 ? '' : 's' %> over <%= result.termDays %> days.</p>
          </div>
          <div class="max-h-96 overflow-y-auto">
            <table class="w-full text-sm">
              <thead class="bg-slate-50 text-xs font-bold uppercase tracking-wider text-slate-500 sticky top-0">
                <tr>
                  <th class="px-5 py-2 text-left">#</th>
                  <th class="px-5 py-2 text-left">Date</th>
                  <th class="px-5 py-2 text-right">Amount</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <% schedule.forEach(s => { %>
                  <tr>
                    <td class="px-5 py-2"><%= s.day %></td>
                    <td class="px-5 py-2 text-slate-600"><%= fmt.date(s.date) %></td>
                    <td class="px-5 py-2 text-right font-medium"><%= fmt.money(s.amount) %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      <% } %>
    <% } else { %>
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-8 text-center">
        <div class="w-16 h-16 mx-auto rounded-full bg-brand-100 text-brand-600 flex items-center justify-center mb-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
        </div>
        <h3 class="font-bold text-slate-900">Try our calculator</h3>
        <p class="text-sm text-slate-500 mt-1">Enter a loan amount and term to see your daily payment.</p>
      </div>
    <% } %>
  </div>
</div>
