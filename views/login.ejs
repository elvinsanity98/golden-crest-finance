<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login · Golden Crest Finance</title>
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Cpath d='M32 3 L57 12 V31 C57 47 46 57 32 61 C18 57 7 47 7 31 V12 Z' fill='%23054e5f'/%3E%3Ctext x='32' y='42' font-size='26' font-weight='800' text-anchor='middle' fill='%23da8850' font-family='Arial,sans-serif'%3EGC%3C/text%3E%3C/svg%3E">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = { theme: { extend: { colors: {
      brand: { 100:'#f6edd2', 200:'#edd9a4', 300:'#e2c477', 400:'#d6ad4c', 500:'#cf9f37', 600:'#b1842a', 700:'#8c6823', 900:'#54401b' },
      ink: { DEFAULT:'#054e5f', 800:'#053f4d', 900:'#04323d' }
    }, fontFamily: { sans: ['Inter','system-ui','sans-serif'] } } } };
  </script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>body { font-family: 'Inter', system-ui, sans-serif; }</style>
</head>
<body class="min-h-screen bg-ink flex items-center justify-center p-4 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-ink via-ink-900 to-brand-900/40"></div>
  <div class="absolute -top-24 -right-24 w-96 h-96 bg-brand-500/20 rounded-full blur-3xl"></div>
  <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-brand-700/20 rounded-full blur-3xl"></div>

  <div class="relative w-full max-w-md">
    <div class="text-center mb-8">
      <span class="relative inline-flex w-20 h-20 mb-4 rounded-2xl bg-white shadow-2xl p-2.5">
        <img src="/img/gc-icon.png" alt="Golden Crest Finance" class="w-full h-full object-contain" onerror="this.style.display='none';this.nextElementSibling.style.display='inline-flex'">
        <span style="display:none" class="absolute inset-0 items-center justify-center rounded-2xl bg-gradient-to-br from-brand-300 to-brand-500 text-ink font-extrabold text-2xl">GC</span>
      </span>
      <h1 class="text-3xl font-extrabold text-white">Golden Crest Finance</h1>
      <p class="text-brand-200 text-sm mt-1">Lending made simple.</p>
    </div>

    <div class="bg-white rounded-2xl shadow-2xl p-6 sm:p-8">
      <h2 class="text-xl font-bold text-ink">Sign in</h2>
      <p class="text-sm text-slate-500 mt-1">Welcome back. Please enter your credentials.</p>

      <% if (error) { %>
        <div class="mt-4 rounded-lg px-4 py-3 text-sm bg-red-50 text-red-800 border border-red-200"><%= error %></div>
      <% } %>

      <form method="POST" action="/login" class="mt-6 space-y-4">
        <div>
          <label class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-1">Username</label>
          <input name="username" type="text" autocomplete="username" required autofocus class="w-full rounded-lg border border-slate-300 px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" placeholder="admin">
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-1">Password</label>
          <input name="password" type="password" autocomplete="current-password" required class="w-full rounded-lg border border-slate-300 px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" placeholder="••••••••">
        </div>
        <button class="w-full bg-gradient-to-r from-brand-500 to-brand-600 hover:from-brand-400 hover:to-brand-500 text-ink font-bold py-2.5 rounded-lg shadow-lg transition">Sign In</button>
      </form>

      <div class="mt-6 pt-4 border-t border-slate-100 text-center">
        <a href="/calculator" class="text-xs text-slate-500 hover:text-brand-600 font-medium">Try our loan calculator without logging in →</a>
      </div>
    </div>

    <p class="mt-6 text-center text-xs text-slate-400">
      &copy; <%= new Date().getFullYear() %> Golden Crest Finance · Owned by Marvin Trinidad<br>
      Developed by <a href="https://www.facebook.com/elvinsanity98/" target="_blank" rel="noopener" class="font-semibold text-brand-400 hover:text-brand-300">Marvin's Friend</a>
    </p>
  </div>
</body>
</html>
